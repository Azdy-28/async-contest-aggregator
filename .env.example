# Copy this file to .env and adjust as needed -- every value here is
# optional; the defaults shown below are what config.py falls back to
# if a variable isn't set. Loaded automatically at startup via python-dotenv.

# How often (seconds) the background worker refreshes the cache.
REFRESH_INTERVAL_SECONDS=300

# Per-attempt HTTP timeout (seconds) for each platform fetch.
HTTP_TIMEOUT_SECONDS=10

# Attempts per platform, per refresh cycle, before giving up for that cycle.
MAX_RETRIES=3

# Exponential backoff base (seconds^attempt) between retries.
RETRY_BACKOFF_BASE=1.5

# Cache is flagged "stale" in API responses after this many seconds
# without a successful full refresh (data is still served either way).
CACHE_STALE_AFTER_SECONDS=900
